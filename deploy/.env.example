# Copy to deploy/.env and fill in real values before `podman-compose up`.
# Never commit deploy/.env — it holds real credentials.

# --- financial-tracker's own Postgres ---
FT_POSTGRES_USER=financial_tracker
FT_POSTGRES_PASSWORD=CHANGE_ME
FT_POSTGRES_DB=financial_tracker

# --- ledger-service (optional — see deploy/README.md's "ledger-service is
# optional" section; only used when you run with --profile ledger) ---
LEDGER_POSTGRES_USER=ledger
LEDGER_POSTGRES_PASSWORD=CHANGE_ME
LEDGER_POSTGRES_DB=ledger_db
# Git ref the ledger-service app image is built from — no local checkout
# needed. Pin to a tag, or point at a fork, e.g.
# https://github.com/you/ledger-service.git#v1.2.0
# (ledger-postgres's init/migration SQL is a local copy under
# deploy/ledger-postgres/, not pulled from this URL — keep both in sync if
# you fork/change ledger-service's schema.)
LEDGER_SERVICE_GIT_URL=https://github.com/JorgeSaicoski/ledger-service.git#main

# --- Authentik (identity provider) ---
# The hostname this whole stack is reached at once INFRA-03's proxy is up
# (e.g. financial-tracker.example.com, or financial-tracker.local for
# homelab use with a manual /etc/hosts entry — see deploy/README.md).
# Authentik itself is reached at auth.<APP_HOSTNAME>.
APP_HOSTNAME=financial-tracker.local
AUTHENTIK_POSTGRES_USER=authentik
AUTHENTIK_POSTGRES_PASSWORD=CHANGE_ME
AUTHENTIK_POSTGRES_DB=authentik
# Generate with: openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=CHANGE_ME
# Consumed by deploy/authentik/blueprints/financial-tracker.yaml to create
# the OAuth2 Provider + Application automatically on first boot — see
# deploy/README.md's Authentik section for the one-time admin setup that
# still has to happen by hand (Authentik itself requires it) and which of
# these values BACK-02/FRONT-04 read.
PUBLIC_OIDC_CLIENT_ID=financial-tracker
PUBLIC_OIDC_REDIRECT_URI=https://financial-tracker.local:8443/auth/callback

# --- financial-tracker app config ---
# No auth yet (BACK-02/INFRA-02 land Authentik); every request without an
# explicit user_id is attributed to this fixed id. Must be a lowercase UUID
# (ledger-service requirement). Stays relevant even after Authentik lands —
# a self-hosted single-user deployment can keep using it.
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
DEFAULT_CURRENCY=usd
SYNC_INTERVAL=30s
SYNC_RETRY_COOLDOWN=60s
# Only meaningful with --profile ledger; defaults to this stack's own
# ledger-service. Point it at an external instance if you're not running
# ledger-service in this compose project at all.
LEDGER_SERVICE_URL=http://ledger-service:8080

# --- frontend ---
# Browser-facing URL for the API. Until INFRA-03's reverse proxy exists,
# point this at wherever you've exposed financial-tracker (see README's
# "Verifying without a proxy yet"); once INFRA-03 lands this becomes the
# proxy's public /api path instead.
PUBLIC_API_URL=http://localhost:8081
