LEDGER_SERVICE_URL=http://localhost:8080
PORT=8081

# MVP has no auth: requests without an explicit user_id are attributed to
# this fixed dev user. Must be a lowercase UUID (ledger-service requirement).
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
DEFAULT_CURRENCY=usd

# Local database - the source of truth for movements. DB_DRIVER selects
# sqlite (default, uses DB_PATH) or postgres (uses DATABASE_URL).
DB_DRIVER=sqlite
DB_PATH=./data/financial-tracker.db
# DATABASE_URL=postgres://user:password@localhost:5432/financial_tracker?sslmode=disable

# Postgres connection pool bounds (only used when DB_DRIVER=postgres).
# Defaults shown below are sized for one API instance; uncomment to tune.
# POSTGRES_MAX_OPEN_CONNS=10
# POSTGRES_MAX_IDLE_CONNS=5
# POSTGRES_CONN_MAX_LIFETIME=30m
# POSTGRES_CONN_MAX_IDLE_TIME=5m

# Background sync to ledger-service (Go duration strings).
SYNC_INTERVAL=30s
SYNC_RETRY_COOLDOWN=60s
